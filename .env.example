# Server-side model calls. Never expose these as NEXT_PUBLIC_* variables.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_ROUTER_MODEL=gpt-5.4
OPENAI_ROUTER_TIMEOUT_MS=25000
OPENAI_REASONING_ENABLED=true
OPENAI_REASONING_EFFORT=medium
OPENAI_REASONING_SUMMARY=auto

# Live paper search providers.
# Semantic Scholar works without a key for light testing, but a key improves rate limits.
SEMANTIC_SCHOLAR_API_KEY=

# Recommended by Crossref polite pool etiquette.
CROSSREF_MAILTO=

# Optional OpenAlex API key if your account/provider setup requires it.
OPENALEX_API_KEY=
